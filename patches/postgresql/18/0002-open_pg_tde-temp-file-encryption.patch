--- a/src/backend/storage/file/tempfile_crypt.c
+++ b/src/backend/storage/file/tempfile_crypt.c
@@ -0,0 +1,27 @@
+/*-------------------------------------------------------------------------
+ *
+ * tempfile_crypt.c
+ *	  Hook points for temporary (query-spill) file encryption.
+ *
+ * Core provides only the switch and the hook pointers. An extension loaded
+ * via shared_preload_libraries installs temp_file_encrypt_hook and
+ * temp_file_decrypt_hook and supplies the cipher and key. See
+ * tempfile_crypt.h.
+ *
+ * The whole file compiles to nothing unless the tree is built with the
+ * open_pg_tde hooks enabled.
+ *
+ *-------------------------------------------------------------------------
+ */
+#include "postgres.h"
+
+#ifdef USE_TDE_HOOKS
+
+#include "storage/tempfile_crypt.h"
+
+bool		encrypt_temp_files = false;
+
+TempFileCryptHook temp_file_encrypt_hook = NULL;
+TempFileCryptHook temp_file_decrypt_hook = NULL;
+
+#endif							/* USE_TDE_HOOKS */
--- a/src/include/storage/tempfile_crypt.h
+++ b/src/include/storage/tempfile_crypt.h
@@ -0,0 +1,40 @@
+/*-------------------------------------------------------------------------
+ *
+ * tempfile_crypt.h
+ *	  Hook interface for encrypting temporary (query-spill) files.
+ *
+ * Core does not implement any cipher. When encrypt_temp_files is on and an
+ * extension has installed the hooks below, each temporary-file buffer is
+ * passed through them before being written and after being read. The
+ * extension owns the cipher and the key, so key management (for example a
+ * principal key from a key management system wrapping an internal key) lives
+ * entirely outside core.
+ *
+ * This interface is only present when the tree is built with the open_pg_tde
+ * hooks enabled (--enable-tde-hooks / -Dtde_hooks).
+ *
+ *-------------------------------------------------------------------------
+ */
+#ifndef TEMPFILE_CRYPT_H
+#define TEMPFILE_CRYPT_H
+
+#ifdef USE_TDE_HOOKS
+
+#include "c.h"
+
+/* GUC: master switch for temporary file encryption (default off). */
+extern PGDLLIMPORT bool encrypt_temp_files;
+
+/*
+ * Encrypt or decrypt one temporary-file buffer in place. blocknum is the
+ * logical block position of the buffer within the BufFile; an implementation
+ * uses it to derive a per-block IV. The transformation must preserve length.
+ */
+typedef void (*TempFileCryptHook) (char *data, int nbytes, int64 blocknum);
+
+extern PGDLLIMPORT TempFileCryptHook temp_file_encrypt_hook;
+extern PGDLLIMPORT TempFileCryptHook temp_file_decrypt_hook;
+
+#endif							/* USE_TDE_HOOKS */
+
+#endif							/* TEMPFILE_CRYPT_H */
