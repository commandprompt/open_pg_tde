-- Change it back to encrypted
ALTER TABLE country_table SET ACCESS METHOD tde_heap;
INSERT INTO country_table (country_name, continent)
     VALUES ('China', 'Asia'),
            ('Brazil', 'South America'),
            ('Australia', 'Oceania');
SELECT * FROM country_table;
 country_id | country_name |   continent   
------------+--------------+---------------
          1 | Japan        | Asia
          2 | UK           | Europe
          3 | USA          | North America
          4 | France       | Europe
          5 | Germany      | Europe
          6 | Canada       | North America
          7 | China        | Asia
          8 | Brazil       | South America
          9 | Australia    | Oceania
(9 rows)

SELECT open_pg_tde_is_encrypted('country_table');
 open_pg_tde_is_encrypted 
--------------------------
